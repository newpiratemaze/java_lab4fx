<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="450.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lab4fx.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <TextArea fx:id="inputField" prefHeight="200.0" prefWidth="200.0" />
      <Button mnemonicParsing="false" onAction="#processSystem" text="Вычислить" />
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button fx:id="loadBtn" mnemonicParsing="false" onAction="#SaveToFile" text="Сохранить" />
            <Button fx:id="saveBtn" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#ReadFromFile" text="Загрузить" />
         </children>
      </HBox>
      <ListView fx:id="outputField" prefHeight="200.0" prefWidth="200.0" />
   </children>
</VBox>
